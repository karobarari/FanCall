# Server environment. Copy this to server/.env and fill in real values.
# The real server/.env is gitignored — never commit it.

DATABASE_URL=postgres://karod@localhost:5432/fancall
# Set to true when the DB requires TLS (Render external URL, Supabase, Neon).
# Leave false for local Postgres and Render's same-region internal URL.
DATABASE_SSL=false
JWT_SECRET=replace-with-a-long-random-string
CLIENT_ORIGIN=http://localhost:5173
PORT=3000
NODE_ENV=development

# Where uploaded profile avatars are written. Leave unset locally (defaults to
# ./uploads/avatars next to the process). In production set this to a MOUNTED
# PERSISTENT DISK path — otherwise avatars are wiped on every redeploy/restart
# (the server logs a warning at boot if this is unset in production).
# On Render: add a Persistent Disk mounted at e.g. /var/data, then set:
#   AVATAR_UPLOADS_DIR=/var/data/avatars
AVATAR_UPLOADS_DIR=

# The one account allowed to settle fixtures. Set this to your login email,
# otherwise the settle endpoint will refuse everyone.
ADMIN_EMAIL=

# Google OAuth. Leave blank to disable "Continue with Google" (returns 503).
# Console: https://console.cloud.google.com/apis/credentials
# Redirect URI must exactly match one registered on the OAuth client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Sign in with Apple. Leave blank to disable "Continue with Apple" (returns
# 503). Requires a paid Apple Developer account. APPLE_CLIENT_ID is the
# Services ID you create (e.g. com.fancall.web), not the app's bundle ID.
# APPLE_PRIVATE_KEY is the .p8 file's contents with newlines escaped as \n.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=http://localhost:3000/api/auth/apple/callback

# Automated fixtures + results feed (football-data.org free tier — no card).
# Register at https://www.football-data.org/client/register to get a key, then
# an admin can POST /api/fixtures/sync to pull the Premier League schedule and
# auto-settle finished matches. Leave blank to disable (sync returns 503; keep
# entering fixtures manually). Partial integration — no scheduler yet.
FOOTBALL_DATA_API_KEY=